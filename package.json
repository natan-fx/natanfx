{
  "name": "natanfx",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "pnpm lint && pnpm type-check && next build",
    "start": "next start",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --write"],
    "*.{json,css,md}": ["biome format --write"]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/edge-config": "^1.4.0",
    "geist": "^1.7.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "quick-lru": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
